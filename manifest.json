{
  "manifest_version": 3,
  "name": "CodeRadar",
  "version": "1.0.0",
  "description": "Smart autocomplete for LeetCode's code editor — powered by a Trie-based suggestion engine.",
  "host_permissions": [
    "https://leetcode.com/*",
    "https://leetcode.cn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/contest/*/problems/*",
        "https://leetcode.com/explore/*",
        "https://leetcode.cn/problems/*",
        "https://leetcode.cn/contest/*/problems/*"
      ],
      "js": ["src/trie.js", "src/tokenizer.js", "src/popup.js", "src/content.js"],
      "css": ["styles/popup.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
